{
  "schemaVersion": 1,
  "id": "${mod_id}",
  "version": "${mod_version}",
  "name": "${mod_name}",
  "description": "${mod_desc}",
  "authors": [
    "${mod_author}"
  ],
  "license": "MIT",
  "icon": "assets/${mod_id}/icon.png",
  "contact": {
    "homepage": "https://github.com/oliveryasuna/minecraft-mods",
    "issues": "https://github.com/oliveryasuna/minecraft-mods/issues",
    "sources": "https://github.com/oliveryasuna/minecraft-mods"
  },
  "environment": "*",
  "entrypoints": {
    "main": [
      "com.oliveryasuna.mc.ssd.SSDMod"
    ],
    "client": [
      "com.oliveryasuna.mc.ssd.client.SSDClientMod"
    ]
  },
  "depends": {
    "fabricloader": ">=${fabric_loader_version}",
    "fabric-api": "*",
    "minecraft": "${minecraft_version}",
    "java": ">=${java_version}"
  }
}
