{
  "schemaVersion": 1,
  "id": "omniconfig",
  "version": "0.1.0",
  "name": "OmniConfig",
  "description": "Multi-loader Minecraft mod configuration library.",
  "authors": [
    "Oliver Yasuna"
  ],
  "license": "MIT",
  "icon": "assets/omniconfig/icon.png",
  "contact": {
    "homepage": "https://github.com/oliveryasuna/workshop-mods",
    "issues": "https://github.com/oliveryasuna/workshop-mods/issues",
    "sources": "https://github.com/oliveryasuna/workshop-mods"
  },
  "environment": "*",
  "entrypoints": {
    "main": [
      "com.oliveryasuna.mc.omniconfig.fabric.OmniConfigFabricMod"
    ],
    "client": [
      "com.oliveryasuna.mc.omniconfig.fabric.OmniConfigFabricClientMod"
    ],
    "modmenu": [
      "com.oliveryasuna.mc.omniconfig.fabric.gui.ModMenuIntegration"
    ]
  },
  "depends": {
    "fabricloader": ">=0.16.0",
    "minecraft": ">=1.21.1",
    "java": ">=21",
    "fabric-api": "*"
  },
  "suggests": {
    "modmenu": "*",
    "yet_another_config_lib_v3": "*",
    "catalogue": "*"
  }
}
