{
  "schemaVersion": 1,
  "id": "${mod_id}",
  "version": "${mod_version}",
  "name": "${mod_name}",
  "description": "${mod_desc}",
  "authors": [
    "${mod_author}"
  ],
  "license": "MIT",
  "contact": {
    "homepage": "https://github.com/oliveryasuna/minecraft-mods",
    "issues": "https://github.com/oliveryasuna/minecraft-mods/issues",
    "sources": "https://github.com/oliveryasuna/minecraft-mods"
  },
  "environment": "*",
  "entrypoints": {
    "main": [
      "com.oliveryasuna.mc.coal.cloth.fabric.ClothAdapterFabricMod"
    ],
    "client": [
      "com.oliveryasuna.mc.coal.cloth.fabric.ClothAdapterFabricClientMod"
    ]
  },
  "depends": {
    "fabricloader": ">=${fabric_loader_version}",
    "fabric-api": "*",
    "minecraft": "${minecraft_version}",
    "java": ">=${java_version}",
    "coal": "*",
    "cloth-config": "*"
  },
  "custom": {
    "modmenu": {
      "badges": [
        "library"
      ]
    }
  }
}
